+int
+mdb_put_ttl(MDB_txn *txn, MDB_dbi dbi,
+    MDB_val *key, MDB_val *data, mdb_time_t expire)
+{
+	MDB_cursor mc;
+	MDB_xcursor mx;
+	int rc;
+	DKBUF;
+	DDBUF;
+
+	if (!key || !data || !TXN_DBI_EXIST(txn, dbi, DB_USRVALID))
+		return EINVAL;
+
+	if (expire <= 0)
+		return MDB_BAD_TTL;
+
+	if (txn->mt_flags & (MDB_TXN_RDONLY|MDB_TXN_BLOCKED))
+		return (txn->mt_flags & MDB_TXN_RDONLY) ? EACCES : MDB_BAD_TXN;
+
+	MDB_TRACE(("%p, %u, %"Z"u[%s], %"Z"u%s, %ld",
+		txn, dbi, key ? key->mv_size:0, DKEY(key), data->mv_size, mdb_dval(txn, dbi, data, dbuf), (long)expire));
+	mdb_cursor_init(&mc, txn, dbi, &mx);
+	mc.mc_next = txn->mt_cursors[dbi];
+	txn->mt_cursors[dbi] = &mc;
+	/* Store the expiration timestamp in cursor context for _mdb_cursor_put */
+	mc.mc_expire = expire;
+	rc = _mdb_cursor_put(&mc, key, data, MDB_TTL);
+	txn->mt_cursors[dbi] = mc.mc_next;
+	return rc;
+}
+
