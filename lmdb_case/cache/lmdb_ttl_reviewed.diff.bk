+
+/** Purge a batch of expired keys from the main database.
+ * This is an internal helper for mdb_purge_expired.
+ * @param[in] txn Transaction handle.
+ * @param[in] dbi Database handle.
+ * @param[in] expired_keys Array of keys to delete.
+ * @param[in] count Number of keys in the array.
+ * @return 0 on success, non-zero on error.
+ */
+static int
+mdb_purge_batch(MDB_txn *txn, MDB_dbi dbi, MDB_val *expired_keys, size_t count)
+{
+	int rc = 0;
+	size_t i;
+	for (i = 0; i < count; i++) {
+		rc = mdb_del0(txn, dbi, &expired_keys[i], NULL, MDB_NODUPDATA);
+		if (rc) {
+			if (rc == MDB_NOTFOUND) {
+				/* Key might have been deleted already, continue */
+				rc = 0;
+				continue;
+			}
+			break;
+		}
+	}
+	return rc;
+}
+
