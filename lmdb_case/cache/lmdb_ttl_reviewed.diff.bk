+/** Initialize the TTL database handle for a transaction.
+ * Opens the internal TTL database if not already open.
+ *
+ * @param[in] txn The transaction handle.
+ * @param[out] dbi Pointer to store the TTL database handle.
+ * @return 0 on success, non-zero on failure.
+ */
+static int
+mdb_ttl_dbi_init(MDB_txn *txn, MDB_dbi *dbi)
+{
+	int rc;
+	MDB_env *env = txn->mt_env;
+	
+	if (env->me_ttl_dbi != 0) {
+		*dbi = env->me_ttl_dbi;
+		return MDB_SUCCESS;
+	}
+	
+	rc = mdb_dbi_open(txn, MDB_TTL_DB_NAME, MDB_CREATE | MDB_INTEGERKEY | MDB_DUPSORT, dbi);
+	if (rc == MDB_SUCCESS) {
+		env->me_ttl_dbi = *dbi;
+		txn->mt_ttl_dbi = *dbi;
+	}
+	
+	return rc;
+}
